<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.bookmark.server</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/bin/python3</string>
    <string>__BOOKMARK_DIR__/server.py</string>
  </array>
  <key>WorkingDirectory</key>
  <string>__BOOKMARK_DIR__</string>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>__BOOKMARK_DIR__/logs/server.log</string>
  <key>StandardErrorPath</key>
  <string>__BOOKMARK_DIR__/logs/server.log</string>
</dict>
</plist>
